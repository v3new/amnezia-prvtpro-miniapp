# Telegram
TG_BOT_TOKEN=
TG_BOT_USERNAME=
TG_BOT_MODE=webhook
TG_WEBHOOK_SECRET=
TG_ADMIN_ID=
TG_ADMIN_HANDLE=

# Mini App / HTTP
PORT=8000
MINI_APP_URL=https://vpn.example.com
JWT_SECRET=
SESSION_TTL_HOURS=24

# Внутренние крон-эндпоинты
CRON_SECRET=

# Amnezia-Web-Panel
PANEL_BASE_URL=http://amnezia-panel:5000
PANEL_API_TOKEN=
PANEL_SERVER_ID=0

# Опционально: хост VPN-сервера (домен или IP, можно с портом), который мини-апп
# будет пинговать с клиента по HTTPS, чтобы показать честный RTT телефон → VPN-хост
VPN_SERVER_HOST=

# VPN-настройки по умолчанию
DEFAULT_PROTOCOL=awg2
ENABLED_PROTOCOLS=awg2,xray,wireguard
MAX_CONNECTIONS_PER_USER=6

# Донат
DONATE_URL=https://www.tinkoff.ru/rm/r_XXXXXXXXXX.YYYYYYYY

# Прочее
TZ=Europe/Moscow
LOG_LEVEL=info
