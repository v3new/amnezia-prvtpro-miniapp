{
  "name": "amnezia-prvtpro-miniapp",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.1.34",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "build": "bun install --cwd client && bun run --cwd client build",
    "start": "bun run server/src/index.ts",
    "dev": "bun --watch run server/src/index.ts",
    "dev:client": "bun run --cwd client dev",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "bunx tsc --noEmit -p server/tsconfig.json && bunx tsc --noEmit -p client/tsconfig.json",
    "test": "bun test"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "grammy": "^1.30.0",
    "zod": "^3.23.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
